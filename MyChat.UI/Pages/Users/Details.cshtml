@page
@model MyChat.UI.Pages.Users.DetailsModel
@{
    ViewData["Title"] = "Min Profil";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-white border-0 pt-4 text-center">
                    <div class="bg-primary text-white rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 80px; height: 80px;">
                        <span class="h2 mb-0">@Model.User.Identity!.Name</span>
                    </div>
                    <h3 class="fw-bold">Profilinställningar</h3>
                </div>

                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show" role="alert">
                        <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }

                <div class="card-body px-4 pb-4">
                    <form method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger small"></div>

                        <div class="mb-3">
                            <label asp-for="NewUserName" class="form-label small fw-bold text-muted text-uppercase">Användarnamn</label>
                            <input asp-for="NewUserName" class="form-control form-control-lg bg-light" placeholder="Välj ett nytt namn" />
                            <span asp-validation-for="NewUserName" class="text-danger small"></span>
                        </div>

                        <div class="d-grid gap-2">

                            <button type="submit" class="btn btn-primary btn-lg shadow-sm">Spara ändringar</button>
                        </div>
                    </form>

                    <div class="card shadow-sm border-0 mb-4">
                        <div class="card-body p-4">
                            <h5 class="fw-bold mb-3 text-primary">Byt lösenord</h5>

                            <form method="post" asp-page-handler="ChangePassword">
                                <div class="mb-3">
                                    <label asp-for="CurrentPassword" class="form-label small fw-bold text-muted text-uppercase">Nuvarande lösenord</label>
                                    <input asp-for="CurrentPassword" type="password" class="form-control form-control-lg bg-light" placeholder="Ange ditt nuvarande lösenord">
                                    <span asp-validation-for="CurrentPassword" class="text-danger small"></span>
                                </div>

                                <hr class="my-4 text-muted opacity-25">

                                <div class="mb-3">
                                    <label asp-for="NewPassword" class="form-label small fw-bold text-muted text-uppercase">Nytt lösenord</label>
                                    <input asp-for="NewPassword" type="password" class="form-control form-control-lg bg-light" placeholder="Välj ett starkt lösenord">
                                    <span asp-validation-for="NewPassword" class="text-danger small"></span>
                                </div>

                                <div class="mb-3">
                                    <label asp-for="ConfirmPassword" class="form-label small fw-bold text-muted text-uppercase">Bekräfta nytt lösenord</label>
                                    <input asp-for="ConfirmPassword" type="password" class="form-control form-control-lg bg-light" placeholder="Upprepa lösenordet">
                                    <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                                </div>

                                <div class="d-grid gap-2 mt-4">
                                    <button type="submit" class="btn btn-primary btn-lg shadow-sm">Uppdatera lösenord</button>
                                </div>
                                <a asp-page="/Users/Messages" class="btn btn-link text-muted mt-2">← Tillbaka till meddelanden</a>
                            </form>
                        </div>
                    </div>

                    <div class="card shadow-sm border-danger mt-5">
                        <div class="card-header bg-danger text-white fw-bold">
                            <i class="bi bi-exclamation-triangle-fill me-2"></i> Riskzon
                        </div>
                        <div class="card-body">
                            <h5 class="card-title text-danger">Hantera data & konto</h5>
                            <p class="card-text text-muted">
                                Här kan du rensa din historik eller ta bort ditt konto helt. Observera att dessa åtgärder inte går att ångra.
                                Om du inte rensar din historik innan du tar bort ditt konto kommer dina tidigare meddelanden att finnas kvar.
                            </p>

                            <div class="d-flex gap-3 flex-wrap">

                                <form method="post" asp-page-handler="ClearHistory">
                                    <button type="submit" class="btn btn-outline-danger"
                                            onclick="return confirm('Är du säker? Detta tar bort ALLA dina meddelanden men behåller ditt konto.')">
                                        <i class="bi bi-eraser-fill"></i> Rensa bara historik
                                    </button>
                                </form>

                                <form method="post" asp-page-handler="DeleteAccount">
                                    <button type="submit" class="btn btn-danger"
                                            onclick="return confirm('Är du helt säker? Du kommer inte kunna logga in igen.')">
                                        <i class="bi bi-person-x-fill"></i> Radera mitt konto permanent
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>