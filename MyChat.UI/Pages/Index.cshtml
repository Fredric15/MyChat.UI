@page
@model IndexModel
@{
    ViewData["Title"] = "Home page";
}

<div class="container d-flex flex-column justify-content-center align-items-center" style="min-height: 85vh;">

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show auto-expire shadow-sm mb-4" role="alert" style="width: 100%; max-width: 450px;">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="text-center mb-5">
        <h1 class="display-3 fw-bold text-dark mb-0" style="letter-spacing: -2px;">MyChat<span class="text-primary">.</span></h1>
        <p class="text-muted lead">Anslut, snacka och ha kul.</p>
    </div>

    <div class="card login-card p-4 p-md-5 bg-white" style="width: 100%; max-width: 450px;">
        <h3 class="text-center fw-bold mb-4">Logga in</h3>

        <form method="post">

            <div class="mb-3">
                <label class="form-label small fw-bold text-muted text-uppercase">Användarnamn</label>
                <div class="input-group border rounded-3 overflow-hidden shadow-sm bg-white">
                    <span class="input-group-text bg-transparent border-0 pe-0">
                        <i class="bi bi-person text-primary"></i>
                    </span>

                    <input asp-for="UserName" class="form-control border-0 shadow-none py-2" placeholder="Skriv ditt namn..." />

                    <span class="input-group-text bg-transparent border-0 ps-0" style="visibility: hidden;">
                        <button class="btn p-0 pe-2"><i class="bi bi-eye"></i></button>
                    </span>
                </div>
                <span asp-validation-for="UserName" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label class="form-label small fw-bold text-muted">LÖSENORD</label>
                <div class="input-group border rounded-3 overflow-hidden shadow-sm bg-white">
                    <span class="input-group-text bg-transparent border-0 pe-0">
                        <i class="bi bi-lock text-primary"></i>
                    </span>

                    <input asp-for="Password" type="password" class="form-control border-0 shadow-none py-2" placeholder="Ditt lösenord..." />

                    <span class="input-group-text bg-transparent border-0 ps-0">
                        <button class="btn border-0 bg-transparent password-toggle-btn text-muted shadow-none p-0 pe-2" type="button">
                            <i class="bi bi-eye"></i>
                        </button>
                    </span>
                </div>
                <span asp-validation-for="Password" class="text-danger small"></span>
            </div>

            <div class="d-grid gap-2">
                <button type="submit" class="btn btn-primary btn-lg shadow-sm py-3 fw-bold">
                    Logga in <i class="bi bi-arrow-right ms-2"></i>
                </button>
            </div>
        </form>

        <div class="text-center mt-4">
            <p class="small text-muted mb-1">Har du inget konto?</p>
            <a asp-page="/Register" class="text-decoration-none fw-bold">Skapa ett nytt konto nu</a>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Vänta tills sidan har laddats helt
        document.addEventListener("DOMContentLoaded", function() {
            // Hitta alla element med klassen 'auto-expire'
            const alerts = document.querySelectorAll('.auto-expire');

            alerts.forEach(function(alert) {
                // Skapa en timer (5000 millisekunder = 5 sekunder)
                setTimeout(function() {
                    // Använd Bootstraps inbyggda metod för att stänga meddelandet
                    const bsAlert = new bootstrap.Alert(alert);
                    bsAlert.close();
                }, 3000);
            });
        });
    </script>
}
