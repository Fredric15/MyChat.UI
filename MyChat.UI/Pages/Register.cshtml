@page
@model MyChat.UI.Pages.RegisterModel
@{
    ViewData["Title"] = "Skapa konto";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5 col-lg-4">
            <div class="card shadow border-0 mt-5">
                <div class="card-body p-5">
                    <h2 class="text-center fw-bold mb-4">Gå med i MyChat</h2>
                    <p class="text-center text-muted small mb-4">Fyll i uppgifterna nedan för att börja chatta.</p>
                    
                    <form method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>



                        <div class="mb-3">
                            <label class="form-label small fw-bold text-muted">Användarnamn</label>
                            <div class="input-group custom-password-group">
                                <input asp-for="UserName" type="text" class="form-control border-end-0 pwd-input" placeholder="Användarnamn" />
                                <span class="input-group-text bg-white border-start-0"></span>
                            </div>
                            <span asp-validation-for="UserName" class="text-danger small"></span>
                        </div>
                        

                        <div class="mb-3">
                            <label class="form-label small fw-bold text-muted">NYTT LÖSENORD</label>
                            <div class="input-group custom-password-group">
                                <input asp-for="Password" type="password" class="form-control border-end-0 pwd-input" placeholder="Välj ett starkt lösenord" />
                                <span class="input-group-text bg-white border-start-0">
                                    <button class="btn btn-link p-0 text-muted password-toggle-btn shadow-none" type="button">
                                        <i class="bi bi-eye"></i>
                                    </button>
                                </span>
                            </div>
                            <span asp-validation-for="Password" class="text-danger small"></span>
                        </div>


                        <div class="mb-3">
                            <label class="form-label small fw-bold text-muted">BEKRÄFTA LÖSENORD</label>
                            <div class="input-group custom-password-group">
                                <input asp-for="ConfirmPassword" type="password" class="form-control border-end-0 pwd-input" placeholder="Bekräfta ditt lösenord" />
                                <span class="input-group-text bg-white border-start-0">
                                    <button class="btn btn-link p-0 text-muted password-toggle-btn shadow-none" type="button">
                                        <i class="bi bi-eye"></i>
                                    </button>
                                </span>
                            </div>
                            <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                        </div>

                        <button type="submit" class="btn btn-primary btn-lg w-100 shadow-sm mb-3">Skapa konto</button>
                    </form>

                    <hr />

                    <div class="text-center mt-4">
                        <p class="text-muted small mb-2">Har du redan ett konto?</p>
                        <a asp-page="./Index" class="btn btn-outline-secondary w-100">Logga in här</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>