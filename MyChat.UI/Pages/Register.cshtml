@page
@model MyChat.UI.Pages.RegisterModel
@{
    ViewData["Title"] = "Skapa konto";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5 col-lg-4">
            <div class="card shadow border-0 mt-5">
                <div class="card-body p-5">
                    <h2 class="text-center fw-bold mb-4">Gå med i MyChat</h2>
                    <p class="text-center text-muted small mb-4">Fyll i uppgifterna nedan för att börja chatta.</p>
                    
                    <form method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                        <div class="mb-3">
                            <label class="form-label small fw-bold">Användarnamn</label>
                            <input asp-for="UserName" class="form-control form-control-lg" placeholder="Användarnamn" />
                            <span asp-validation-for="UserName" class="text-danger small"></span>
                        </div>
                        
                        <div class="mb-3">
                            <label class="form-label small fw-bold">LÖSENORD</label>
                            <input asp-for="Password" class="form-control form-control-lg" type="password" />
                            <span asp-validation-for="Password" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label class="form-label small fw-bold">BEKRÄFTA LÖSENORD</label>
                            <input asp-for="ConfirmPassword" class="form-control form-control-lg" type="password" />
                            <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                        </div>

                        <button type="submit" class="btn btn-primary btn-lg w-100 shadow-sm mb-3">Skapa konto</button>
                    </form>

                    <hr />

                    <div class="text-center mt-4">
                        <p class="text-muted small mb-2">Har du redan ett konto?</p>
                        <a asp-page="./Index" class="btn btn-outline-secondary w-100">Logga in här</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>